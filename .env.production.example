# ─────────────────────────────────────────────────────────────────────────────
# Variables d'environnement — Production
# Copier vers .env sur le VPS et remplir toutes les valeurs.
# Ne jamais committer ce fichier avec de vraies valeurs.
# ─────────────────────────────────────────────────────────────────────────────

# Base de données SQLite
DATABASE_URL="file:./prod.db"

# Auth.js — générer avec : openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="https://votre-domaine.fr"

# Resend (email transactionnel)
# Vérifier le domaine d'envoi avant le lancement : https://resend.com/domains
RESEND_API_KEY=""
RESEND_FROM_EMAIL="reservation@votre-domaine.fr"

# Cloudinary (images prestations)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# URLs publiques (sans slash final)
NEXT_PUBLIC_SITE_URL="https://votre-domaine.fr"
NEXT_PUBLIC_BUSINESS_NAME="Nom du salon"
NEXT_PUBLIC_BUSINESS_ADDRESS="Adresse complète du salon"

# Compte admin initial — utilisé uniquement par : npm run db:seed
# Changer le mot de passe immédiatement après le premier déploiement.
SEED_ADMIN_EMAIL="admin@votre-domaine.fr"
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="Admin"
