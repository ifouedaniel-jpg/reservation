generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Service {
  id              String         @id @default(cuid())
  slug            String         @unique
  name            String
  description     String
  durationMinutes Int
  priceCents      Int
  priceMatrix     String?        // JSON: PriceMatrix (grid | options)
  active          Boolean        @default(true)
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  bookings        Booking[]
  images          ServiceImage[]
}

model ServiceImage {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  url       String
  publicId  String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([serviceId, order])
}

model RecurringAvailability {
  id          String   @id @default(cuid())
  dayOfWeek   Int      // 0 = dimanche, 6 = samedi
  startTime   String   // "09:00"
  endTime     String   // "18:00"
  slotMinutes Int      @default(30)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlockedDate {
  id        String   @id @default(cuid())
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
}

model TimeSlot {
  id        String    @id @default(cuid())
  startsAt  DateTime  @unique // toujours stocké en UTC — début de la fenêtre de dispo
  endsAt    DateTime           // fin de la fenêtre de dispo
  status    String    @default("OPEN") // OPEN | CLOSED
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]

  @@index([startsAt, status])
}

model Booking {
  id                  String    @id @default(cuid())
  publicCode          String    @unique @default(cuid())

  customerFirstName   String
  customerPhone       String
  notes               String?
  selectedOptions     String?   // JSON: { type, size?, length?, optionIds?, choiceId? }

  serviceId           String
  service             Service   @relation(fields: [serviceId], references: [id])
  timeSlotId          String
  timeSlot            TimeSlot  @relation(fields: [timeSlotId], references: [id])

  bookingStartsAt     DateTime  // début exact du RDV (UTC), dans la fenêtre
  bookingEndsAt       DateTime  // fin exacte du RDV (UTC), dans la fenêtre

  priceCentsAtBooking Int

  paymentReference    String?
  paymentProofUrl     String?

  status              String    @default("PENDING") // PENDING|CONFIRMED|REJECTED|CANCELLED|COMPLETED|NO_SHOW
  cancellationReason  String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  confirmedAt         DateTime?
  cancelledAt         DateTime?

  notifications       NotificationLog[]
  products            BookingProduct[]

  @@index([status, createdAt])
  @@index([timeSlotId])
  @@index([bookingStartsAt])
}

model Product {
  id          String           @id @default(cuid())
  name        String
  description String?
  priceCents  Int
  imageUrl    String?
  active      Boolean          @default(true)
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  bookings    BookingProduct[]
}

model BookingProduct {
  id                  String   @id @default(cuid())
  bookingId           String
  booking             Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  productId           String
  product             Product  @relation(fields: [productId], references: [id])
  quantity            Int      @default(1)
  priceCentsAtBooking Int
  createdAt           DateTime @default(now())

  @@index([bookingId])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model NotificationLog {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  channel   String   // WHATSAPP | INSTAGRAM | SMS | EMAIL
  type      String   // BOOKING_RECEIVED | BOOKING_CONFIRMED | BOOKING_REJECTED | BOOKING_CANCELLED | REMINDER_24H
  status    String   // SENT | FAILED | MANUAL_REQUIRED
  payload   String
  error     String?
  sentAt    DateTime @default(now())

  @@index([bookingId])
}
